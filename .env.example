# Copy to ".env" and fill in from your Supabase project
# (Dashboard → Project Settings → Data API / API Keys).
# Both values are safe to expose in a public frontend — Row-Level Security
# enforces all access rules server-side. NEVER put the service_role key here.
VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY
