{
  "compilerOptions": {
    "target": "ES2021",
    "useDefineForClassFields": true,
    "lib": ["ES2021", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",

    /* The legacy app is still plain JS+JSX. Allow it, but don't type-check it
       yet — types are tightened incrementally (see plan). New code is .ts/.tsx
       and IS type-checked. */
    "allowJs": true,
    "checkJs": false,

    /* Linting — applies to the typed (.ts/.tsx) surface */
    "strict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": true
  },
  "include": ["src", "vite.config.ts"],
  "comment": "Test files are exercised by Vitest (which type-strips); they render the loosely-typed legacy .jsx components, so we don't type-check them against those over-strict inferred signatures.",
  "exclude": ["src/__tests__"]
}
